# === Required ===

# Azure OpenAI (for verifier + skill evolution)
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com

# AppWorld root directory (contains data/datasets/{train,dev,test_normal,test_challenge}.txt)
# After `pip install appworld && appworld install`, set this to the appworld data directory
APPWORLD_ROOT=/path/to/appworld

# SelfSkill (veRL fork) root directory
# Clone from https://github.com/plzdoo/SelfSkill.git, apply deploy/selfskill.patch
SELFSKILL_ROOT=/path/to/SelfSkill

# === Optional ===

# Weights & Biases (for training logging)
WANDB_API_KEY=your_wandb_key_here

# AppWorld conda environment name (default: appworld_env)
# Create with: conda create -n appworld_env python=3.10 && conda activate appworld_env && pip install appworld
APPWORLD_CONDA_ENV=appworld_env
